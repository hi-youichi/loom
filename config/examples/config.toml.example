# Example: ~/.loom/config.toml
# Copy to ~/.loom/config.toml (or $LOOM_HOME/config.toml) and fill in your values.
# Keys match graphweave/.env; only [env] is read.

[env]
# API
OPENAI_BASE_URL = "https://api.openai.com/v1"
OPENAI_API_KEY = "sk-your-key"
LANGGRAPH_API_KEY = "your-secret-key"

# Logging (CLI writes to LOG_FILE when set; path relative to cwd)
RUST_LOG = "info"
LOG_FILE = "logs/loom.log"

# Model
MODEL = "gpt-4o"
OPENAI_TEMPERATURE = "0.5"

# BigModel (智谱) as chat LLM: use OpenAI vars + LLM_PROVIDER
# LLM_PROVIDER = "bigmodel"
# OPENAI_BASE_URL = "https://open.bigmodel.cn/api/paas/v4"
# OPENAI_API_KEY = "your-bigmodel-key"
# MODEL = "glm-4.7-flash"

# Embedding (e.g. Zhipu)
EMBEDDING_PROVIDER = "zhipuai"
EMBEDDING_API_KEY = "your-embedding-key"
EMBEDDING_BASE_URL = "https://open.bigmodel.cn/api/paas/v4"
EMBEDDING_MODEL = "embedding-2"

# Bot / streaming
BOT_TOKEN = "your-bot-token"
USE_STREAMING = "true"
THINKING_MESSAGE = "Thinking..."

# Memory
MEMORY_STORE_TYPE = "sqlite"
MEMORY_RECENT_LIMIT = "100"
LANCE_DB_PATH = "./data/lancedb"
MEMORY_SQLITE_PATH = "./data/memory.db"

# ReAct / Exa
EXA_API_KEY = "your-exa-key"
MCP_EXA_USE_HTTP = "1"
HELVE_MAX_MESSAGE_LEN = "100"

# Context compression (auto-manage context window)
LOOM_COMPRESSION_AUTO = "true"
LOOM_COMPRESSION_PRUNE = "true"
LOOM_COMPRESSION_MAX_TOKENS = "128000"
LOOM_COMPRESSION_RESERVE_TOKENS = "4096"
LOOM_COMPRESSION_PRUNE_KEEP_TOKENS = "40000"
LOOM_COMPRESSION_PRUNE_MINIMUM = "20000"
LOOM_COMPRESSION_KEEP_RECENT = "20"
