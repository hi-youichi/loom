# Example: ~/.loom/config.toml
# Copy to ~/.loom/config.toml (or $LOOM_HOME/config.toml) and fill in your values.
# Keys match graphweave/.env; only [env] is read.

[env]
# API
OPENAI_BASE_URL = "https://api.openai.com/v1"
OPENAI_API_KEY = "sk-your-key"
LANGGRAPH_API_KEY = "your-secret-key"

# Logging: applied as env vars; loom CLI reads LOG_FILE / RUST_LOG after loading this file.
# LOG_FILE path is relative to cwd unless you use {working_folder} with -w/--working-folder.
RUST_LOG = "info"
LOG_FILE = "logs/loom.log"

# Model
MODEL = "gpt-4o"
OPENAI_TEMPERATURE = "0.5"

# OpenAI-compat chat (e.g. Zhipu BigModel): use OpenAI vars + LLM_PROVIDER
# LLM_PROVIDER = "openai_compat"
# (alias: "bigmodel" still works)
# LLM_PROVIDER = "bigmodel"
# OPENAI_BASE_URL = "https://open.bigmodel.cn/api/paas/v4"
# OPENAI_API_KEY = "your-bigmodel-key"
# MODEL = "glm-4.7-flash"

# Embedding (e.g. Zhipu)
EMBEDDING_PROVIDER = "zhipuai"
EMBEDDING_API_KEY = "your-embedding-key"
EMBEDDING_BASE_URL = "https://open.bigmodel.cn/api/paas/v4"
EMBEDDING_MODEL = "embedding-2"

# Bot / streaming
BOT_TOKEN = "your-bot-token"
USE_STREAMING = "true"
THINKING_MESSAGE = "Thinking..."

# Memory
MEMORY_STORE_TYPE = "sqlite"
MEMORY_RECENT_LIMIT = "100"
LANCE_DB_PATH = "./data/lancedb"
MEMORY_SQLITE_PATH = "./data/memory.db"

# ReAct / Exa
EXA_API_KEY = "your-exa-key"
MCP_EXA_USE_HTTP = "1"
HELVE_MAX_MESSAGE_LEN = "100"

# Context compression (auto-manage context window)
LOOM_COMPRESSION_AUTO = "true"
LOOM_COMPRESSION_PRUNE = "true"
LOOM_COMPRESSION_MAX_TOKENS = "128000"
LOOM_COMPRESSION_RESERVE_TOKENS = "4096"
LOOM_COMPRESSION_PRUNE_KEEP_TOKENS = "40000"
LOOM_COMPRESSION_PRUNE_MINIMUM = "20000"
LOOM_COMPRESSION_KEEP_RECENT = "20"

# Optional: named providers (use [default].provider to select one).
# Per-provider tool_choice sets OPENAI_TOOL_CHOICE (auto, none, required); same as [env].
# Per-provider temperature sets OPENAI_TEMPERATURE (decimal); same as [env].
# [[providers]]
# name = "openai"
# api_key = "sk-your-key"
# base_url = "https://api.openai.com/v1"
# model = "gpt-4o"
# type = "openai"
# tool_choice = "auto"
# temperature = 0.7
# fetch_models = true              # Fetch model list from {base_url}/models
                                   # (missing or false = use models.dev catalog)
