{
  "name": "@graphweave/hooks",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@graphweave/protocol": "workspace:*",
    "@graphweave/types": "workspace:*",
    "@graphweave/adapters": "workspace:*",
    "@graphweave/ws-client": "workspace:*",
    "@graphweave/service-session": "workspace:*",
    "@graphweave/service-workspace": "workspace:*",
    "@graphweave/service-agent": "workspace:*",
    "@graphweave/service-chat": "workspace:*"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
